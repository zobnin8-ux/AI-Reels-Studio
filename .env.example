# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# Set to 1 for offline mock (no API keys needed)
AI_MOCK_MODE=0
NEXT_PUBLIC_AI_MOCK_MODE=0

# Chat + images (when mock is off)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional overrides
# OPENAI_CHAT_MODEL=gpt-4o-mini
# Для русского контента в чате часто стабильнее: gpt-4o
# OPENAI_IMAGE_MODEL=gpt-image-2
# Старый вариант: gpt-image-1 | dall-e-3
# OPENAI_IMAGE_QUALITY=high
# ANTHROPIC_MODEL=
